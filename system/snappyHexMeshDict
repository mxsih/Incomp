FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh true;
snap            true;
addLayers       false;

geometry
{
    NACA0012
    {
        type triSurfaceMesh;
        file "NACA0012.obj";
    }
    refinementBox
    {
        type box;
        min  (1.5 0.5 0.5);
        max  (5.5 1.5 3.5);
    }
}

castellatedMeshControls
{
    maxLocalCells 1000000;
    maxGlobalCells 2000000;
    minRefinementCells 100;
    nCellsBetweenLevels 1;

    features
    (
    );

    refinementSurfaces
    {
        NACA0012
        {
            level (2 2);
            patchInfo
            {
                type wall;
            }
        }
    }

    resolveFeatureAngle 60;

    refinementRegions
    {
        refinementBox
        {
            mode inside;
            levels ((1.0 1));
        }
    }

    locationInMesh (0.1 1.0 0.1);
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch 3;
    tolerance 2.0;
    nSolveIter 30;
    nRelaxIter 5;
    nFeatureSnapIter 10;
    implicitFeatureSnap true;
    explicitFeatureSnap false;
}

addLayersControls
{
    relativeSizes true;
    layers
    {
    }
    expansionRatio 1.0;
    finalLayerThickness 0.5;
    minThickness 0.05;
    nGrow 0;
    featureAngle 180;
    nRelaxIter 5;
    maxFaceThicknessRatio 0.5;
    nSmoothThickness 10;
    meshShrinker displacementMotionSolver;
    solver displacementLaplacian;
    displacementLaplacianCoeffs
    {
        diffusivity quadratic inverseDistance ("NACA0012");
    }
    nBufferCellsNoExtrude -1;
    nLayerIter 50;
}

meshQualityControls
{
    #include "meshQualityDict"
    nSmoothScale 4;
    errorReduction 0.75;
}

mergeTolerance 1e-6;

// ************************************************************************* //
